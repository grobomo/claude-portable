# === Authentication (choose ONE mode) ===

# Mode 1: Anthropic API Key (simplest -- individual, teams)
# Get from: console.anthropic.com > API Keys > Create Key
ANTHROPIC_API_KEY=

# Mode 2: OAuth tokens (enterprise / Claude Max -- auto-extracted by Claude)
CLAUDE_OAUTH_ACCESS_TOKEN=
CLAUDE_OAUTH_REFRESH_TOKEN=
CLAUDE_OAUTH_EXPIRES_AT=

# Mode 3: Bitwarden Secrets Manager (production)
# BWS_ACCESS_TOKEN=

# === GitHub token (needed to clone this repo onto EC2) ===
# Run: gh auth token  (or create at github.com/settings/tokens)
GITHUB_TOKEN=

# === Repo URL (how EC2 clones this repo) ===
REPO_URL=https://github.com/grobomo/claude-portable.git

# === Optional: MCP Server tokens ===
# V1_API_TOKEN=
# CONFLUENCE_API_TOKEN=
# JIRA_API_TOKEN=
# TRELLO_API_TOKEN=

# === Optional: SSH public key for rsync ===
# SSH_PUBLIC_KEY=ssh-ed25519 AAAA... user@laptop

# === Optional: Auto-shutdown on idle (remote mode only) ===
# Minutes of inactivity before EC2 instance stops (default: 30)
# CLAUDE_PORTABLE_IDLE_TIMEOUT=30

# === Optional: S3 state backup ===
# Auto-derived from AWS account if not set (claude-portable-state-<account-id>)
# CLAUDE_PORTABLE_STATE_BUCKET=
# AWS_DEFAULT_REGION=us-east-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
