# === Authentication (choose ONE mode) ===

# Mode 1: Bitwarden Secrets Manager (recommended for production)
# BWS_ACCESS_TOKEN=<your-bws-machine-account-token>

# Mode 2: Direct env vars (simpler, good for local dev)
CLAUDE_OAUTH_ACCESS_TOKEN=
CLAUDE_OAUTH_REFRESH_TOKEN=
CLAUDE_OAUTH_EXPIRES_AT=
GITHUB_TOKEN=

# === MCP Server tokens (direct mode) ===
V1_API_TOKEN=
CONFLUENCE_API_TOKEN=
JIRA_API_TOKEN=
TRELLO_API_TOKEN=

# === SSH for rsync file sync ===
# SSH_PUBLIC_KEY=ssh-ed25519 AAAA... user@laptop

# === Container config ===
# CLAUDE_PORTABLE_MCP_ORG=<your-github-org>
# CLAUDE_PORTABLE_MCP_REPOS=mcp-manager mcp-v1-lite mcp-wiki-lite mcp-jira-lite mcp-trello-lite mcp-trendgpt
# CLAUDE_PORTABLE_SERVERS=wiki-lite,v1-lite,jira-lite,trello-lite

# === EC2 remote deployment ===
# CLAUDE_PORTABLE_EC2_INSTANCE=i-xxx
# CLAUDE_PORTABLE_EC2_KEY=~/.ssh/claude-portable.pem
# CLAUDE_PORTABLE_AWS_PROFILE=default
# CLAUDE_PORTABLE_AWS_REGION=us-east-2
