# === Authentication (choose ONE mode) ===

# Mode 1: Anthropic API Key (simplest -- individual, teams)
# Get from: console.anthropic.com > API Keys > Create Key
ANTHROPIC_API_KEY=

# Mode 2: OAuth tokens (enterprise / Claude Max -- auto-extracted by Claude)
CLAUDE_OAUTH_ACCESS_TOKEN=
CLAUDE_OAUTH_REFRESH_TOKEN=
CLAUDE_OAUTH_EXPIRES_AT=

# Mode 3: Bitwarden Secrets Manager (production)
# BWS_ACCESS_TOKEN=

# === GitHub token (needed to clone this repo onto EC2) ===
# Run: gh auth token  (or create at github.com/settings/tokens)
GITHUB_TOKEN=

# === Repo URL (how EC2 clones this repo) ===
REPO_URL=https://github.com/grobomo/claude-portable.git

# === Optional: MCP Server tokens ===
# V1_API_TOKEN=
# CONFLUENCE_API_TOKEN=
# JIRA_API_TOKEN=
# TRELLO_API_TOKEN=

# === Optional: SSH public key for rsync ===
# SSH_PUBLIC_KEY=ssh-ed25519 AAAA... user@laptop

# === Optional: Web Chat (phone access) ===
# Auth token for the web chat interface. Auto-generated if not set.
# CLAUDE_WEB_TOKEN=

# === Optional: Auto-shutdown on idle (remote mode only) ===
# Minutes of inactivity before EC2 instance stops (default: 30)
# CLAUDE_PORTABLE_IDLE_TIMEOUT=30

# === Optional: Continuous Claude (autonomous task runner) ===
# Set ENABLED=true and REPO to a GitHub repo URL to auto-run tasks from TODO.md
# CONTINUOUS_CLAUDE_ENABLED=true
# CONTINUOUS_CLAUDE_REPO=https://github.com/your-org/your-project.git
# CONTINUOUS_CLAUDE_BRANCH=main

# === Optional: Dispatcher (Teams integration) ===
# Teams chat ID to monitor for @claude messages. Can also be set in ccc.config.json
# as "dispatcher_chat_id". If neither is set, ccc will prompt when launching --role dispatcher.
# DISPATCHER_CHAT_ID=
# DISPATCHER_SECRET_NAME=claude-portable/graph-token
# DISPATCHER_TRIGGER=@claude
# DISPATCHER_POLL_INTERVAL=15

# === Optional: Worker registration ===
# URL of the dispatcher health endpoint. Workers POST /worker/register here on boot.
# Auto-injected by the dispatcher into .env when it starts (via EC2 private IP).
# Set manually if workers can't reach the dispatcher by auto-detected IP.
# DISPATCHER_URL=http://10.0.1.50:8080
# DISPATCHER_IP=10.0.1.50   (overrides auto-detection of dispatcher's own IP)
# WORKER_REGISTRATION_TIMEOUT=300  (seconds; workers that don't register are terminated)

# === Optional: S3 state backup ===
# Auto-derived from AWS account if not set (claude-portable-state-<account-id>)
# CLAUDE_PORTABLE_STATE_BUCKET=
# AWS_DEFAULT_REGION=us-east-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
