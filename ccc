        cmd_cancel(args)
    elif args.command in ("maintenance", "maint"):
        cmd_maintenance(args)
    elif args.command == "work":
        cmd_work(args)
    elif args.command == "health":
        cmd_health_api(args)
    elif args.command == "interrupt":
        cmd_interrupt_api(args)
    elif args.command == "pull":
        cmd_pull_api(args)
    elif args.command == "bundle":
        # Delegate to config-bundle.py
        bundle_script = os.path.join(os.path.dirname(os.path.abspath(__file__)),
                                      "scripts", "config-bundle.py")
        cmd = [sys.executable, bundle_script, args.action]
        if hasattr(args, "name") and args.name:
            cmd.extend(["--name", args.name])
        if hasattr(args, "all") and args.all:
            cmd.append("--all")
        if args.action == "patch" and args.files:
            cmd.extend(args.files)
        subprocess.run(cmd)
    else:
        cmd_connect(args)

