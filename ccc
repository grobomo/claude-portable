    p_cancel.add_argument("--cleanup", action="store_true", help="Also delete the in-progress branch and close PR")
    p_maint = sub.add_parser("maintenance", aliases=["maint"], help="Pause/resume task pickup on a worker")
    p_maint.add_argument("name", help="Instance name")
    p_maint.add_argument("--off", action="store_true", help="Resume task pickup (exit maintenance)")
