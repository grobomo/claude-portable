        print(f"\n  Dispatcher launched: {inst['label']} ({inst['ip']})")
        print(f"  Logs: ssh -i {ssh_key} ubuntu@{inst['ip']} 'docker logs -f claude-portable'")
        print(f"  SSH:  ssh -i {ssh_key} ubuntu@{inst['ip']}")
    elif is_chatbot:
        setup_instance(inst["ip"], ssh_key, inst["label"])
        push_credentials(inst["ip"], ssh_key)
        # Wait a moment for web-chat to write its token
        time.sleep(3)
        web_token_cmd = "docker exec claude-portable cat /data/web-chat-token 2>/dev/null || true"
        token = _ssh_exec(inst["ip"], ssh_key, web_token_cmd).strip()
        lambda_url = CFG.get("web_chat_lambda_url", "")
