def cmd_work(args):
    """Show what each worker is doing: branch, PR status, task progress, maintenance mode."""
    import re
    instances = get_instances()
    workers = [i for i in instances if i.get("role", "worker") not in ("dispatcher", "chatbot")]

    print("=" * 70)
    print("  CCC Worker Activity")
    print("=" * 70)

