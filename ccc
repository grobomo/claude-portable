                "if [ -f /workspace/continuous-claude/TODO.md ]; then "
                "  total=$(grep -cE '^- \\\\[' /workspace/continuous-claude/TODO.md 2>/dev/null || echo 0); "
                "  done=$(grep -cE '^- \\\\[x\\\\]' /workspace/continuous-claude/TODO.md 2>/dev/null || echo 0); "
                "  echo \"$done/$total\"; "
                "else echo '?'; fi")
            maint = _ssh_exec(ip, ssh_key, "test -f /data/.maintenance && echo PAUSED || echo ACTIVE")
            print(f"      Continuous-claude: running (PID {cc_pid}) [{maint}]")
            if maint == "PAUSED":
                print(f"      ** MAINTENANCE MODE — task pickup paused **")
            if last_iter:
                print(f"      Last iteration: {last_iter.strip()}")
            print(f"      Tasks: {tasks_info}")
        else:
            maint = _ssh_exec(ip, ssh_key, "test -f /data/.maintenance && echo PAUSED || echo ''")
            status = "not running (MAINTENANCE)" if maint == "PAUSED" else "not running"
            print(f"      Continuous-claude: {status}")

        # Idle time
        idle = _ssh_exec(ip, ssh_key,
            "cat /data/idle-monitor.log 2>/dev/null | tail -1 || true")
        if idle:
            print(f"      Idle monitor: {idle[:80]}")

    # Fleet-wide: open PRs across all repos with continuous-claude branches
    print(f"\n  {'=' * 60}")
    print(f"  Open PRs (continuous-claude branches)")
    print(f"  {'=' * 60}")

    # Check for a repo URL from any running instance
    repo_url = ""
    for inst in running:
        ssh_key = find_ssh_key(inst)
        if ssh_key and inst.get("ip"):
            repo_url = _ssh_exec(inst["ip"], ssh_key,
                "cd /workspace/continuous-claude 2>/dev/null && git remote get-url origin 2>/dev/null || true")
            if repo_url:
                break

    if repo_url:
        # Extract owner/repo from URL
        import re
        m = re.search(r'github\.com[/:]([^/]+/[^/.]+)', repo_url)
        if m:
            repo_slug = m.group(1)
            try:
                r = subprocess.run(
                    ["gh", "pr", "list", "--repo", repo_slug, "--state", "open",
                     "--json", "number,title,headRefName,author,createdAt",
                     "--jq", '.[] | select(.headRefName | startswith("continuous-claude/"))'],
                    capture_output=True, text=True, timeout=15)
                if r.returncode == 0 and r.stdout.strip():
                    for line in r.stdout.strip().split("\n"):
                        try:
                            pr = json.loads(line)
                            author = pr.get("author", {}).get("login", "?")
                            print(f"    #{pr['number']:<5} {pr['headRefName']:<35} {pr['title'][:40]}")
                        except json.JSONDecodeError:
                            pass
                else:
                    # Try without jq filter
                    r2 = subprocess.run(
                        ["gh", "pr", "list", "--repo", repo_slug, "--state", "open",
                         "--json", "number,title,headRefName"],
                        capture_output=True, text=True, timeout=15)
                    if r2.returncode == 0 and r2.stdout.strip():
                        prs = json.loads(r2.stdout)
                        cc_prs = [p for p in prs if p.get("headRefName", "").startswith("continuous-claude/")]
                        if cc_prs:
                            for pr in cc_prs:
                                print(f"    #{pr['number']:<5} {pr['headRefName']:<35} {pr['title'][:40]}")
                        else:
                            print("    (none)")
                    else:
                        print("    (could not fetch)")
            except Exception as e:
                print(f"    (error: {e})")
        else:
            print(f"    (could not parse repo URL: {repo_url})")
    else:
        print("    (no repo detected on any instance)")

    # Remote branches
    if repo_url:
        try:
            r = subprocess.run(
                ["git", "ls-remote", "--heads", repo_url, "refs/heads/continuous-claude/*"],
                capture_output=True, text=True, timeout=15)
            branches = [line.split("refs/heads/")[-1] for line in r.stdout.strip().split("\n") if line]
            if branches:
                print(f"\n  Active branches:")
                for b in branches:
                    print(f"    {b}")
            else:
                print(f"\n  No active continuous-claude branches.")
        except Exception:
            pass

    print()


def cmd_cancel(args):
    """Kill Claude processes on an instance to cancel in-progress work."""
    name = args.name
    inst = find_available(name)
    if not inst:
        print("No instance found." + (f" ({name})" if name else ""))
        return
    if inst["state"] != "running":
        print(f"  Instance {inst.get('label', '?')} is {inst['state']}.")
        return

    ssh_key = find_ssh_key(inst)
    if not ssh_key:
        print("ERROR: No SSH key found.")
        return

    ip = inst["ip"]
    label = inst.get("label", "?")

    if args.all_procs:
        # Kill everything: continuous-claude runner + all Claude CLI processes
        print(f"  Killing ALL Claude processes on {label}...")
        _ssh_exec(ip, ssh_key, "pkill -f continuous-claude.sh || true", timeout=10)
        _ssh_exec(ip, ssh_key, "pkill -f 'node.*claude' || true", timeout=10)
        _ssh_exec(ip, ssh_key, "pkill -f 'claude.*--print' || true", timeout=10)
        print("  Done. All Claude processes killed.")
    else:
        # Kill only the current Claude CLI invocation (not the runner loop)
        print(f"  Killing current Claude task on {label}...")
        _ssh_exec(ip, ssh_key, "pkill -f 'claude.*--print' || true", timeout=10)
        _ssh_exec(ip, ssh_key, "pkill -f 'node.*claude' || true", timeout=10)
        print("  Done. Current task killed (runner will pick up next task).")

    # Optionally clean up the branch
    if args.cleanup:
        print("  Cleaning up branch...")
        branch = _ssh_exec(ip, ssh_key,
            "cd /workspace/continuous-claude 2>/dev/null && git branch --show-current || true")
        if branch and branch.startswith("continuous-claude/"):
            _ssh_exec(ip, ssh_key,
                f"cd /workspace/continuous-claude && git checkout main && git branch -D {branch} && "
                f"git push origin --delete {branch} 2>/dev/null || true", timeout=15)
            # Close any open PR for this branch
            subprocess.run(
                ["gh", "pr", "close", branch, "--delete-branch"],
                capture_output=True, timeout=15)
            print(f"  Deleted branch {branch} and closed any PR.")
        else:
            print(f"  Not on a continuous-claude branch ({branch}).")


def cmd_maintenance(args):
    """Toggle maintenance mode on workers — pauses task pickup, SSH still works."""
    if args.all_workers:
        instances = [i for i in get_instances() if i["state"] == "running"
                     and i.get("role", "worker") not in ("dispatcher", "chatbot")]
        if not instances:
            print("No running workers.")
            return
        for inst in instances:
            ssh_key = find_ssh_key(inst)
            if not ssh_key:
                continue
            ip = inst.get("ip", "")
            label = inst.get("label", "?")
            if not ip:
                continue
            if args.off:
                _ssh_exec(ip, ssh_key, "rm -f /data/.maintenance", timeout=10)
                print(f"  {label}: maintenance OFF")
            else:
                _ssh_exec(ip, ssh_key, "touch /data/.maintenance", timeout=10)
                print(f"  {label}: maintenance ON")
        return

    name = args.name
    if not name:
        print("Usage: ccc maint <name> or ccc maint --all")
        return
    inst = find_available(name)
    if not inst:
        print(f"No instance found." + (f" ({name})" if name else ""))
        return
    if inst["state"] != "running":
        print(f"  Instance {inst.get('label', '?')} is {inst['state']}.")
        return

    ssh_key = find_ssh_key(inst)
    if not ssh_key:
        print("ERROR: No SSH key found.")
        return

    ip = inst["ip"]
    label = inst.get("label", "?")

    if args.off:
        _ssh_exec(ip, ssh_key, "rm -f /data/.maintenance", timeout=10)
        print(f"  {label}: maintenance OFF — task pickup resumed.")
    else:
        _ssh_exec(ip, ssh_key, "touch /data/.maintenance", timeout=10)
        print(f"  {label}: maintenance ON — task pickup paused. SSH still works.")
        print(f"  Resume with: ccc maintenance {name} --off")


# ── Worker HTTP API commands ────────────────────────────────────────────────

WORKER_API_PORT = 8081

def _worker_api_call(name, method, path):
    """Call the worker health API via its public IP."""
    inst = find_available(name)
    if not inst:
        print(f"  Instance '{name}' not found.")
        return None
    if inst["state"] != "running":
        print(f"  Instance '{name}' is {inst['state']}, not running.")
        return None
    ip = inst.get("ip", "")
    if not ip:
        print(f"  Instance '{name}' has no IP.")
        return None

    import urllib.request
    url = f"http://{ip}:{WORKER_API_PORT}{path}"
    try:
        req = urllib.request.Request(url, method=method,
                                     data=b"{}" if method == "POST" else None,
                                     headers={"Content-Type": "application/json"})
        with urllib.request.urlopen(req, timeout=10) as resp:
            return json.loads(resp.read().decode())
    except Exception as e:
        print(f"  API call failed ({url}): {e}")
        print(f"  (Is worker-health.py running on the instance?)")
        return None


def cmd_health_api(args):
    """Get worker health via HTTP API."""
    data = _worker_api_call(args.name, "GET", "/health")
    if not data:
        return
    print(f"\n  Worker: {data.get('worker_id', '?')}")
    print(f"  Uptime: {data.get('uptime_seconds', 0)}s")
    print(f"  Claude: {'running' if data.get('claude_running') else 'idle'}")
    print(f"  Maintenance: {'yes' if data.get('maintenance') else 'no'}")
    task = data.get("task", {})
    if task.get("task_num"):
        print(f"  Task: #{task['task_num']} - {task.get('description', '')[:60]}")
        print(f"  Branch: {task.get('branch', '')}")
    else:
        print(f"  Task: none")
    pipeline = data.get("pipeline", {})
    print(f"  Stage: {pipeline.get('stage', '?')} ({pipeline.get('stages_complete', 0)}/6)")
    if data.get("pull_pending"):
        print(f"  Pull: PENDING")
    if data.get("interrupt_pending"):
        print(f"  Interrupt: PENDING")
    print()


