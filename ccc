        if lambda_url:
            print(f"  Lambda:   {lambda_url}")
        print(f"  SSH:  ssh -i {ssh_key} ubuntu@{inst['ip']}")
        print(f"  Logs: ssh -i {ssh_key} ubuntu@{inst['ip']} 'docker logs -f claude-portable'")
    else:
        setup_instance(inst["ip"], ssh_key, inst["label"])
        push_credentials(inst["ip"], ssh_key)
        start_idle_monitor(inst["ip"], ssh_key)

        if continuous_repo or env_vars.get("CONTINUOUS_CLAUDE_ENABLED") == "true":
            print(f"\n  Worker launched: {inst['label']} ({inst['ip']})")
            print(f"  Continuous-claude will auto-start via bootstrap.")
            print(f"  Monitor: ccc status {name or inst['label']}")
            print(f"  Logs:    ccc logs -f {name or inst['label']}")
            # Don't open terminal tab — worker is autonomous
        else:
            connect(inst["ip"], ssh_key, inst["label"])

