        print("\n  No worker instances found.\n")
        return

    running = [i for i in workers if i["state"] == "running"]
    stopped = [i for i in workers if i["state"] == "stopped"]
    print(f"\n  Workers: {len(running)} running, {len(stopped)} stopped\n")

    # Collect repo slug once from any running instance
    repo_slug = None
    for inst in running:
        ssh_key = find_ssh_key(inst)
        if ssh_key and inst.get("ip"):
            repo_url = _ssh_exec(inst["ip"], ssh_key,
                "cd /workspace/continuous-claude 2>/dev/null && git remote get-url origin 2>/dev/null || true")
            if repo_url:
                m = re.search(r'github\.com[/:]([^/]+/[^/.]+?)(?:\.git)?$', repo_url.strip())
                if m:
                    repo_slug = m.group(1)
                    break

    for inst in workers:
        label = inst.get("label") or inst.get("name", "?")
        state = inst["state"]
        ip = inst.get("ip", "")
        state_icon = ">>>" if state == "running" else "---"
        print(f"  {state_icon} {label}  ({state})  {ip}  {inst.get('type','')}")

        if state != "running" or not ip:
            print()
            continue

        ssh_key = find_ssh_key(inst)
        if not ssh_key:
            print("      (no SSH key)\n")
            continue

        # Maintenance mode
        maint = _ssh_exec(ip, ssh_key, "test -f /data/.maintenance && echo PAUSED || echo ACTIVE")
        maint_str = "  [MAINTENANCE]" if maint == "PAUSED" else ""

        # Current branch
        branch = _ssh_exec(ip, ssh_key,
            "cd /workspace/continuous-claude 2>/dev/null && git branch --show-current 2>/dev/null || echo ''")
        branch = branch or "(none)"

        # Continuous-claude running?
        cc_pid = _ssh_exec(ip, ssh_key, "pgrep -f continuous-claude.sh || true")
        cc_status = f"running (PID {cc_pid.splitlines()[0]})" if cc_pid else "not running"

        # Task progress from TODO.md
        tasks_info = _ssh_exec(ip, ssh_key,
            "if [ -f /workspace/continuous-claude/TODO.md ]; then "
            "  total=$(grep -cE '^- \\[' /workspace/continuous-claude/TODO.md 2>/dev/null || echo 0); "
            "  done=$(grep -cE '^- \\[x\\]' /workspace/continuous-claude/TODO.md 2>/dev/null || echo 0); "
            "  echo \"$done/$total\"; "
            "else echo '?'; fi")

        print(f"      Branch:   {branch}{maint_str}")
        print(f"      Runner:   {cc_status}")
        print(f"      Tasks:    {tasks_info}")

        # Stage progress from stage log
        if branch.startswith("continuous-claude/task-"):
            task_match = re.search(r'task-(\d+)', branch)
            if task_match:
                task_n = task_match.group(1)
                stage_json = _ssh_exec(ip, ssh_key,
                    f"cat /data/task-{task_n}-stages.json 2>/dev/null || echo '{{}}'")
                try:
                    stages = json.loads(stage_json or "{}")
                    stage_names = ["RESEARCH", "REVIEW", "PLAN", "TESTS", "IMPLEMENT", "VERIFY", "PR"]
                    current_stage = None
                    passed_stages = []
                    failed_stage = None
                    for s in stage_names:
                        if s in stages:
                            status = stages[s].get("status", "?")
                            if status == "running":
                                current_stage = s
                            elif status == "passed":
                                passed_stages.append(s)
                            elif status == "failed":
                                failed_stage = s
                    n_done = len(passed_stages)
                    if current_stage:
                        print(f"      Stage:    {current_stage} (running) [{n_done}/6 complete]")
                    elif failed_stage:
                        print(f"      Stage:    {failed_stage} (FAILED) [{n_done}/6 complete]")
                    elif n_done == 6:
                        print(f"      Stage:    all 6 stages complete")
                    elif n_done > 0:
                        print(f"      Stage:    {passed_stages[-1]} passed [{n_done}/6 complete]")
                    else:
                        print(f"      Stage:    not started")
                except Exception:
                    pass  # no stage info available

        # PR status for current branch
        if repo_slug and branch and branch != "(none)" and branch.startswith("continuous-claude/"):
            try:
                r = subprocess.run(
                    ["gh", "pr", "list", "--repo", repo_slug,
                     "--head", branch, "--state", "all",
                     "--json", "number,title,state,mergedAt",
                     "--limit", "1"],
                    capture_output=True, text=True, timeout=10)
                if r.returncode == 0 and r.stdout.strip():
                    prs = json.loads(r.stdout)
                    if prs:
                        pr = prs[0]
                        pr_state = pr.get("state", "?").upper()
                        pr_num = pr.get("number", "?")
                        pr_title = pr.get("title", "")[:45]
                        print(f"      PR:       #{pr_num} [{pr_state}] {pr_title}")
                    else:
                        print(f"      PR:       (none for this branch)")
                else:
                    print(f"      PR:       (could not fetch)")
            except Exception as e:
                print(f"      PR:       (error: {e})")
        elif branch != "(none)" and not branch.startswith("continuous-claude/"):
            print(f"      PR:       (not a continuous-claude branch)")
        else:
            print(f"      PR:       (no branch)")

        print()

    # ── Task queue with dependency visualization ──
    print("-" * 70)
    print("  Task Queue (from TODO.md)")
    print("-" * 70)
    todo_path = os.path.join(os.path.dirname(os.path.abspath(__file__)), "TODO.md")
    if os.path.isfile(todo_path):
        with open(todo_path, "r") as f:
            content = f.read()
        lines = content.splitlines()
        # Collect checked line numbers
        checked_lines = set()
        for i, line in enumerate(lines):
            if re.match(r'^\s*-\s+\[x\]', line, re.IGNORECASE):
                checked_lines.add(i + 1)
        # Show unchecked tasks with dependency info
        task_num = 0
        for i, line in enumerate(lines):
            if not re.match(r'^\s*-\s+\[\s+\]', line):
                continue
            task_num += 1
            desc = re.sub(r'^\s*-\s+\[\s+\]\s+', '', line).strip()
            line_num = i + 1
            # Check for depends-on in sub-lines
            deps = []
            blocked_by = []
            j = i + 1
            while j < len(lines):
                sub = lines[j]
                if re.match(r'^\s*-\s+\[', sub):
                    break
                if not sub.strip() or (sub[0] not in (' ', '\t') and sub.strip()):
                    if not sub.strip():
                        j += 1
                        continue
                    break
                dep_match = re.match(r'^\s*-\s+depends-on:\s*(.+)$', sub, re.IGNORECASE)
                if dep_match:
                    for ref in re.split(r'[,\s]+', dep_match.group(1)):
                        num_m = re.search(r'(\d+)', ref)
                        if num_m:
                            dep_line = int(num_m.group(1))
                            deps.append(dep_line)
                            if dep_line not in checked_lines:
                                blocked_by.append(dep_line)
                j += 1

            if blocked_by:
                status = f"\033[91mBLOCKED\033[0m (waiting on line {', '.join(str(b) for b in blocked_by)})"
            elif deps:
                status = "\033[92mREADY\033[0m (deps met)"
            else:
                status = "\033[92mREADY\033[0m"

            short_desc = desc[:55] + "..." if len(desc) > 55 else desc
            print(f"  L{line_num:>3}  {status:>40}  {short_desc}")

        pending = sum(1 for line in lines if re.match(r'^\s*-\s+\[\s+\]', line))
        done = sum(1 for line in lines if re.match(r'^\s*-\s+\[x\]', line, re.IGNORECASE))
        print(f"\n  Total: {done} done, {pending} pending")
    else:
        print("  (no TODO.md found)")
    print()


