    p_health = sub.add_parser("health", help="Get worker health via HTTP API (no SSH)")
    p_health.add_argument("name", help="Worker name")

    p_interrupt = sub.add_parser("interrupt", help="Interrupt Claude on a worker via HTTP API (no SSH)")
    p_interrupt.add_argument("name", help="Worker name")

    p_pull = sub.add_parser("pull", help="Force git pull on a worker via HTTP API")
    p_pull.add_argument("name", help="Worker name")

    p_bundle = sub.add_parser("bundle", help="Config bundle: scrape, build, deploy, status, patch, simulate")
    p_bundle.add_argument("action", nargs="?", default="status",
                          choices=["scrape", "build", "deploy", "status", "patch", "simulate"],
                          help="Bundle action (default: status)")
