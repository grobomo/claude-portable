{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "0",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "GOOGLE_GEMINI_BASE_URL": "https://api.rdsec.trendmicro.com/prod/aiendpoint",
    "NANO_BANANA_MODEL": "gemini-3-pro-image"
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Edit",
      "Write",
      "Read",
      "Glob",
      "Grep",
      "Bash(python *)",
      "Bash(npm *)",
      "Bash(node *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(mkdir *)",
      "Bash(rm *)",
      "Bash(cp *)",
      "Bash(mv *)"
    ],
    "deny": [
      "Agent"
    ],
    "defaultMode": "bypassPermissions"
  },
  "model": "opus[1m]",
  "enableAllProjectMcpServers": true,
  "enabledPlugins": {},
  "extraKnownMarketplaces": {
    "grobomo-marketplace": {
      "source": {
        "source": "github",
        "repo": "grobomo/claude-code-skills"
      }
    }
  },
  "autoUpdatesChannel": "latest",
  "voiceEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/run-stop.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/run-posttooluse.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/run-posttooluse.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/run-pretooluse.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/run-pretooluse.js\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
